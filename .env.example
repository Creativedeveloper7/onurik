# Repo root `.env` (Vite reads from here via website/vite.config.js envDir)

# Include https:// — `projectref.supabase.co` alone will error in the browser client
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Must match Postgres: update public.onurik_site_settings set value = to_jsonb('YOUR_SECRET'::text)
#   where key = 'dashboard_read_secret';
VITE_ADMIN_DASHBOARD_SECRET=your-dashboard-read-secret

# Optional: alternatively paste keys into HTML `window.__ONURIK_PUBLIC_CONFIG__` before </head>
# on contact.html and admin enquiries/bookings (no rebuild).
